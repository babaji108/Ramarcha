{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "admin", "pandit", "bhakt"] },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role", "name"]
    },
    "Pandit": {
      "title": "Pandit",
      "description": "Religious expert profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "specialization": { "type": "array", "items": { "type": "string" } },
        "experience": { "type": "number" },
        "bio": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "rating": { "type": "number" }
      },
      "required": ["uid"]
    },
    "Puja": {
      "title": "Puja",
      "description": "Available religious services",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["name", "price"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Puja booking record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bhaktId": { "type": "string" },
        "panditId": { "type": "string" },
        "pujaId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "videoLink": { "type": "string" },
        "address": { "type": "string" },
        "vehiclePrepayment": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bhaktId", "pujaId", "date", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "UPI payment record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bookingId": { "type": "string" },
        "amount": { "type": "number" },
        "upiId": { "type": "string" },
        "transactionId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bookingId", "amount", "status"]
    },
    "Event": {
      "title": "Event",
      "description": "Temple events and festivals",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "imageUrl": { "type": "string" }
      },
      "required": ["title", "date"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app and push notification records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["booking", "event", "system"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "link": { "type": "string" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/pandits/{uid}": {
      "schema": "Pandit",
      "description": "Pandit specific details"
    },
    "/pujas/{pujaId}": {
      "schema": "Puja",
      "description": "Puja catalog"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Booking records"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment records"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Temple events"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
